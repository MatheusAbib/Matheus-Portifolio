{
    "description": "Projeto PHP com PHPMailer e DotEnv",
    "type": "project",
    "require": {
        "php": "^8.1",                      
        "ext-mbstring": "*",              
        "ext-openssl": "*",                 
        "vlucas/phpdotenv": "^5.6",          
        "phpmailer/phpmailer": "^6.10"       
    },
    "scripts": {
        "post-install-cmd": [
            "php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "config": {
        "optimize-autoloader": true,          
        "platform-check": false            
    }
}