{
    "name": "seu-projeto/render-deploy",
    "description": "Projeto PHP com PHPMailer",
    "require": {
        "php": "^8.2",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-json": "*",
        "vlucas/phpdotenv": "^5.6",
        "phpmailer/phpmailer": "^6.10"
    },
    "config": {
        "optimize-autoloader": true,
        "platform-check": false,
        "sort-packages": true
    },
    "scripts": {
        "post-install-cmd": [
            "php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    }
}